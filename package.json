{
	"name": "ground-control",
	"version": "1.2.0",
	"description": "Electron+React shell scaffolded from the Andrea architecture reference",
	"main": "./out/main/index.js",
	"author": "",
	"license": "UNLICENSED",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "electron-vite dev",
		"clean": "rm -rf dist out",
		"build": "npm run clean && electron-vite build && electron-builder",
		"build:unpack": "npm run clean && electron-vite build && electron-builder --dir",
		"start": "electron-vite preview",
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"typecheck": "npm run typecheck:node && npm run typecheck:web",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.138",
		"@electron-toolkit/preload": "^3.0.2",
		"@electron-toolkit/utils": "^4.0.0",
		"@fastify/cors": "^11.2.0",
		"diff": "^9.0.0",
		"fastify": "^5.8.5",
		"gitdiff-parser": "^0.3.1",
		"highlight.js": "^11.11.1",
		"p-queue": "^9.2.0",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.15.0",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1",
		"ulid": "^3.0.2",
		"write-file-atomic": "^7.0.1",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^22.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/write-file-atomic": "^4.0.3",
		"@vitejs/plugin-react": "^5.2.0",
		"electron": "^42.0.0",
		"electron-builder": "^26.0.0",
		"electron-vite": "^5.0.0",
		"eslint": "^10.3.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.59.2",
		"vite": "^7.0.0"
	}
}
