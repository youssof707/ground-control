{
	"extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
	"include": [
		"electron.vite.config.*",
		"src/main/**/*",
		"src/preload/**/*",
		"src/shared/**/*"
	],
	"compilerOptions": {
		"composite": true,
		"outDir": "out/types/node",
		"tsBuildInfoFile": "out/types/node.tsbuildinfo",
		"emitDeclarationOnly": true,
		"types": ["electron-vite/node"]
	}
}
